{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Ward",
          "informationUri": "https://github.com/Eljakani/ward",
          "version": "v0.4.0",
          "semanticVersion": "v0.4.0",
          "rules": [
            {
              "id": "ENV-002",
              "name": "APP_DEBUG is enabled",
              "shortDescription": {
                "text": "APP_DEBUG is enabled"
              },
              "fullDescription": {
                "text": "APP_DEBUG is set to true. In production, this exposes detailed error messages including stack traces, database queries, and environment variables to end users."
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Set APP_DEBUG=false in your production .env file. Use Laravel's logging system for error tracking instead."
              },
              "properties": {
                "tags": [
                  "Configuration"
                ],
                "security-severity": "high"
              }
            },
            {
              "id": "ENV-005",
              "name": "APP_ENV is set to 'local'",
              "shortDescription": {
                "text": "APP_ENV is set to 'local'"
              },
              "fullDescription": {
                "text": "The application environment suggests a non-production configuration. If this is a production server, this may cause debug features to be enabled and performance optimizations to be skipped."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Set APP_ENV=production on production servers."
              },
              "properties": {
                "tags": [
                  "Configuration"
                ],
                "security-severity": "medium"
              }
            },
            {
              "id": "CFG-009",
              "name": "CORS allows all origins",
              "shortDescription": {
                "text": "CORS allows all origins"
              },
              "fullDescription": {
                "text": "config/cors.php allows requests from any origin ('*'). This permits cross-site data theft if authenticated endpoints return sensitive data."
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Specify allowed origins: 'allowed_origins' =\u003e [env('FRONTEND_URL')],"
              },
              "properties": {
                "tags": [
                  "Configuration"
                ],
                "security-severity": "medium"
              }
            },
            {
              "id": "CVE-2025-54068",
              "name": "[CVE-2025-54068] livewire/livewire@3.5.8 — Livewire is vulnerable to remote command execution during component property update hydration",
              "shortDescription": {
                "text": "[CVE-2025-54068] livewire/livewire@3.5.8 — Livewire is vulnerable to remote command execution during component property update hydration"
              },
              "fullDescription": {
                "text": "Livewire is vulnerable to remote command execution during component property update hydration"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Upgrade livewire/livewire to 3.6.4 or later:\n  composer require livewire/livewire:3.6.4"
              },
              "properties": {
                "tags": [
                  "Dependencies"
                ],
                "security-severity": "critical"
              }
            },
            {
              "id": "AUTH-001",
              "name": "Route without middleware",
              "shortDescription": {
                "text": "Route without middleware"
              },
              "fullDescription": {
                "text": "A route is defined without any middleware. Depending on the route, this may expose endpoints without authentication or rate limiting. Sensitive routes should always have auth or throttle middleware.\n"
              },
              "defaultConfiguration": {
                "level": "note"
              },
              "help": {
                "text": "Apply middleware to routes:\n  Route::get('/dashboard', [DashboardController::class, 'index'])\n      -\u003emiddleware(['auth', 'verified']);\nOr group routes:\n  Route::middleware(['auth'])-\u003egroup(function () { ... });\n"
              },
              "properties": {
                "tags": [
                  "Authentication"
                ],
                "security-severity": "low"
              }
            },
            {
              "id": "CRYPTO-002",
              "name": "sha1() used for security purposes",
              "shortDescription": {
                "text": "sha1() used for security purposes"
              },
              "fullDescription": {
                "text": "SHA-1 is considered weak — practical collision attacks exist. While less broken than MD5, it should not be used for security-sensitive operations like password hashing or token generation.\n"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Use SHA-256 or stronger:\n  hash('sha256', $data)\nFor passwords, always use Hash::make().\n"
              },
              "properties": {
                "tags": [
                  "Cryptography"
                ],
                "security-severity": "medium"
              }
            },
            {
              "id": "DEBUG-001",
              "name": "dd() call left in code",
              "shortDescription": {
                "text": "dd() call left in code"
              },
              "fullDescription": {
                "text": "dd() (dump and die) stops execution and dumps variable contents to the browser. Left in production code, it breaks functionality and can expose sensitive data structures, database contents, or environment variables.\n"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Remove dd() calls before deploying:\n  Use Laravel Telescope or logging for debugging in non-local environments.\n  Log::debug('message', $context);\n"
              },
              "properties": {
                "tags": [
                  "Debug"
                ],
                "security-severity": "high"
              }
            },
            {
              "id": "DEBUG-003",
              "name": "var_dump() or print_r() in source",
              "shortDescription": {
                "text": "var_dump() or print_r() in source"
              },
              "fullDescription": {
                "text": "Native PHP debug functions output raw data to the browser. In production these expose internal variable contents and data structures.\n"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Replace with structured logging:\n  Log::debug('variable state', ['data' =\u003e $data]);\n"
              },
              "properties": {
                "tags": [
                  "Debug"
                ],
                "security-severity": "medium"
              }
            },
            {
              "id": "CONFIG-001",
              "name": "Wildcard CORS origin allowed",
              "shortDescription": {
                "text": "Wildcard CORS origin allowed"
              },
              "fullDescription": {
                "text": "The CORS configuration allows all origins ('*'). This permits any website to make authenticated cross-origin requests to your API, potentially exposing user data through CSRF-like attacks.\n"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Specify explicit allowed origins:\n  'allowed_origins' =\u003e [env('FRONTEND_URL', 'https://myapp.com')],\n"
              },
              "properties": {
                "tags": [
                  "Configuration"
                ],
                "security-severity": "medium"
              }
            },
            {
              "id": "CONFIG-004",
              "name": "Empty $guarded array on Eloquent model",
              "shortDescription": {
                "text": "Empty $guarded array on Eloquent model"
              },
              "fullDescription": {
                "text": "Setting $guarded = [] makes every attribute mass-assignable. An attacker can inject unexpected fields (is_admin, role, email_verified_at) through mass assignment via create() or update().\n"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "help": {
                "text": "Use $fillable to explicitly list allowed fields:\n  protected $fillable = ['name', 'email', 'password'];\nOr set $guarded to protect sensitive fields:\n  protected $guarded = ['id', 'is_admin', 'role'];\n"
              },
              "properties": {
                "tags": [
                  "Configuration"
                ],
                "security-severity": "high"
              }
            },
            {
              "id": "XSS-001",
              "name": "Unescaped Blade output {!! !!}",
              "shortDescription": {
                "text": "Unescaped Blade output {!! !!}"
              },
              "fullDescription": {
                "text": "The {!! !!} syntax renders raw HTML without escaping. If the value contains user-controlled data, this creates a stored or reflected XSS vulnerability. Use {{ }} which auto-escapes via htmlspecialchars().\n"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Use escaped output:\n  {{ $variable }}        — auto-escapes HTML entities\nIf raw HTML is truly needed, sanitize first:\n  {!! clean($variable) !!}   — use HTMLPurifier or similar\n"
              },
              "properties": {
                "tags": [
                  "XSS"
                ],
                "security-severity": "medium"
              }
            },
            {
              "id": "XSS-003",
              "name": "JavaScript variable from unescaped PHP",
              "shortDescription": {
                "text": "JavaScript variable from unescaped PHP"
              },
              "fullDescription": {
                "text": "A PHP variable is interpolated into a JavaScript block without using @json or proper encoding, which can lead to XSS if the value contains user data.\n"
              },
              "defaultConfiguration": {
                "level": "warning"
              },
              "help": {
                "text": "Use @json to safely embed PHP data in JavaScript:\n  \u003cscript\u003e\n    var data = @json($data);\n  \u003c/script\u003e\nOr use a data attribute:\n  \u003cdiv data-config=\"{{ json_encode($config) }}\"\u003e\n"
              },
              "properties": {
                "tags": [
                  "XSS"
                ],
                "security-severity": "medium"
              }
            }
          ]
        }
      },
